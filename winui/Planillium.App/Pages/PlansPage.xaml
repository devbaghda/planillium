<Page
    x:Class="Planillium.App.Pages.PlansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Enabled">

    <ScrollViewer Padding="28,8,28,28">
        <StackPanel MaxWidth="880" HorizontalAlignment="Center" Spacing="0">
            <Grid Margin="0,8,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Plans" Style="{StaticResource TitleTextBlockStyle}"/>
                <Button x:Name="AddButton" Grid.Column="1" Content="+ Add Plan"
                        Style="{StaticResource AccentButtonStyle}" Click="Add_Click"/>
            </Grid>
            <InfoBar x:Name="LoadErrorBar" Severity="Warning" IsClosable="True"
                     Margin="0,0,0,12"/>
            <InfoBar x:Name="SaveErrorBar"
                     Severity="Error"
                     IsOpen="False"
                     IsClosable="True"
                     Title="Couldn't save that change"
                     Message="The database was briefly busy — try again in a moment."
                     Margin="0,0,0,12"/>
            <StackPanel x:Name="ActiveList" Spacing="10"/>
            <TextBlock Text="QUEUED IDEAS" FontSize="11" FontWeight="SemiBold"
                       CharacterSpacing="60" Margin="2,26,0,8"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <StackPanel x:Name="QueuedList" Spacing="6"/>
            <TextBlock Text="ARCHIVED" FontSize="11" FontWeight="SemiBold"
                       CharacterSpacing="60" Margin="2,26,0,8"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <StackPanel x:Name="ArchivedList" Spacing="6"/>
        </StackPanel>
    </ScrollViewer>
</Page>
