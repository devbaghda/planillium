<Page
    x:Class="Planillium.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="28,8,28,28">
        <StackPanel MaxWidth="720" HorizontalAlignment="Center" Spacing="16">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" Margin="0,8,0,0"/>

            <TextBlock Text="PROFILE" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <!-- Previously set once at first run (NameSetupDialog) with no way to see or
                 change it afterward short of opening config.json directly
                 (2026-07-18 audit finding R10-13). -->
            <TextBox x:Name="YourName" Header="Your name" Width="260" HorizontalAlignment="Left"
                     PlaceholderText="e.g. Alex" LostFocus="YourName_Changed"/>

            <TextBlock Text="APPEARANCE" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <RadioButtons x:Name="ThemeChoice" SelectionChanged="Theme_Changed">
                <RadioButton Content="Follow Windows (recommended)" Tag="default"/>
                <RadioButton Content="Light" Tag="light"/>
                <RadioButton Content="Dark" Tag="dark"/>
            </RadioButtons>
            <Slider x:Name="OpacitySlider" Header="Window opacity (%)" Width="260"
                    HorizontalAlignment="Left" Minimum="40" Maximum="100"
                    StepFrequency="5" TickFrequency="10" TickPlacement="Outside"
                    ValueChanged="Opacity_Changed"/>

            <TextBlock Text="STARTUP" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <ToggleSwitch x:Name="StartupToggle" Header="Start with Windows (minimized to the tray)"
                          Toggled="Startup_Toggled"/>

            <TextBlock Text="TICKTICK" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <TextBlock x:Name="TickTickStatus" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="TickTickConnectBtn" Content="Connect TickTick…"
                        Click="TickTickConnect_Click" HorizontalAlignment="Left"/>
                <Button x:Name="TickTickDisconnectBtn" Content="Disconnect TickTick…"
                        Click="TickTickDisconnect_Click" HorizontalAlignment="Left"
                        Visibility="Collapsed"/>
            </StackPanel>

            <TextBlock Text="TRACKING" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <TextBlock x:Name="TrackerInfo" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <TextBlock Text="HOURS &amp; REMINDERS" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox x:Name="WorkStart" Header="Work start" Width="110" PlaceholderText="08:00" LostFocus="Rules_Changed"/>
                <TextBox x:Name="WorkEnd" Header="Work end" Width="110" PlaceholderText="20:00" LostFocus="Rules_Changed"/>
                <TextBox x:Name="EodTimeBox" Header="Day review at" Width="110" PlaceholderText="20:00" LostFocus="Rules_Changed"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <NumberBox x:Name="GraceMin" Header="Grace before alert (min)" Width="170" Minimum="1" SpinButtonPlacementMode="Compact" ValueChanged="Rules_ValueChanged"/>
                <NumberBox x:Name="RepeatMin" Header="Repeat every (min)" Width="150" Minimum="1" SpinButtonPlacementMode="Compact" ValueChanged="Rules_ValueChanged"/>
                <NumberBox x:Name="IdleMin" Header="Idle after (min)" Width="130" Minimum="1" SpinButtonPlacementMode="Compact" ValueChanged="Rules_ValueChanged"/>
            </StackPanel>
            <!-- Split onto its own row (2026-07-21 fix): together with the row above, these
                 5 boxes needed ~918px, well past this page's 720px MaxWidth content column —
                 a horizontal StackPanel doesn't wrap, so RetentionDays/LateDayReminderHours
                 were silently clipped at the right edge. Reported as "there's no setting for
                 the reminder" even though the control was there, just rendering a sliver wide
                 with its header text truncated to "Warn / (hrs)". -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <!-- Maximum added (2026-07-18 audit finding R11-10): unbounded, this could
                     silently defeat the app's own documented "kept for a configurable
                     number of days, 90 by default" retention promise. -->
                <NumberBox x:Name="RetentionDays" Header="Keep detailed diary (days)" Width="190" Minimum="1" Maximum="3650" SpinButtonPlacementMode="Compact" ValueChanged="Rules_ValueChanged"/>
                <NumberBox x:Name="LateDayReminderHours" Header="Warn if tasks open, before day ends (hrs)" Width="260" Minimum="0.25" Maximum="12" SmallChange="0.25" SpinButtonPlacementMode="Compact" ValueChanged="Rules_ValueChanged"/>
            </StackPanel>

            <TextBlock Text="ACTIVITY KEYWORDS  ·  one per line, matched inside window titles" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="RulesOn" Grid.Column="0" Header="On-plan" AcceptsReturn="True" Height="160" TextWrapping="NoWrap" LostFocus="Rules_Changed"/>
                <TextBox x:Name="RulesOff" Grid.Column="1" Header="Off-plan" AcceptsReturn="True" Height="160" TextWrapping="NoWrap" LostFocus="Rules_Changed"/>
                <TextBox x:Name="RulesNeutral" Grid.Column="2" Header="Neutral" AcceptsReturn="True" Height="160" TextWrapping="NoWrap" LostFocus="Rules_Changed"/>
            </Grid>

            <TextBlock Text="IDLE-ANSWER LIBRARY  ·  classifies what you type after being away" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="IdleOn" Grid.Column="0" Header="Counts as on-plan" AcceptsReturn="True" Height="120" TextWrapping="NoWrap" LostFocus="Rules_Changed"/>
                <TextBox x:Name="IdleOff" Grid.Column="1" Header="Counts as off-plan" AcceptsReturn="True" Height="120" TextWrapping="NoWrap" LostFocus="Rules_Changed"/>
                <TextBox x:Name="IdleNeutral" Grid.Column="2" Header="Counts as neutral" AcceptsReturn="True" Height="120" TextWrapping="NoWrap" LostFocus="Rules_Changed"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock x:Name="SaveStatus" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <TextBlock Text="DATA" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <TextBlock x:Name="DataInfo" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="ExportAllBtn" Content="Export all my data…" Click="ExportAll_Click"/>
                <Button x:Name="ClearHistoryBtn" Content="Clear activity history…" Click="ClearHistory_Click"/>
                <Button x:Name="ClearReflectionsBtn" Content="Clear my reflections…" Click="ClearReflections_Click"/>
                <Button x:Name="ClearAllDataBtn" Content="Clear all my data…" Click="ClearAllData_Click"/>
            </StackPanel>
            <TextBlock Text="Export writes every stored row (tasks, notes, score history, activity diary, evening reflections) to one JSON file. Clearing activity history removes the tracked window-activity diary only; clearing reflections removes your evening-review answers only. &quot;Clear all my data&quot; removes everything at once — task completions, reschedules/day-offs, notes, score history, reflections, TickTick sync links, the activity diary, and the debug log — but never your plan definitions themselves (archive or delete those from the Plans page). Your plans, task completions, and score are always untouched by the two narrower buttons above."
                       TextWrapping="Wrap" FontSize="12"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
