<Page
    x:Class="MentorOverseer.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="28,8,28,28">
        <StackPanel MaxWidth="720" Spacing="16">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" Margin="0,8,0,0"/>

            <TextBlock Text="APPEARANCE" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <RadioButtons x:Name="ThemeChoice" SelectionChanged="Theme_Changed">
                <RadioButton Content="Follow Windows (recommended)" Tag="default"/>
                <RadioButton Content="Light" Tag="light"/>
                <RadioButton Content="Dark" Tag="dark"/>
            </RadioButtons>
            <Slider x:Name="OpacitySlider" Header="Window opacity (%)" Width="260"
                    HorizontalAlignment="Left" Minimum="40" Maximum="100"
                    StepFrequency="5" TickFrequency="10" TickPlacement="Outside"
                    ValueChanged="Opacity_Changed"/>

            <TextBlock Text="STARTUP" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <ToggleSwitch x:Name="StartupToggle" Header="Start with Windows (minimized to the tray)"
                          Toggled="Startup_Toggled"/>

            <TextBlock Text="TICKTICK" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <TextBlock x:Name="TickTickStatus" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Button x:Name="TickTickConnectBtn" Content="Connect TickTick…"
                    Click="TickTickConnect_Click" HorizontalAlignment="Left"/>

            <TextBlock Text="TRACKING" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <TextBlock x:Name="TrackerInfo" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <TextBlock Text="HOURS &amp; REMINDERS" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox x:Name="WorkStart" Header="Work start" Width="110" PlaceholderText="08:00"/>
                <TextBox x:Name="WorkEnd" Header="Work end" Width="110" PlaceholderText="20:00"/>
                <TextBox x:Name="EodTimeBox" Header="Day review at" Width="110" PlaceholderText="20:00"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <NumberBox x:Name="GraceMin" Header="Grace before alert (min)" Width="170" Minimum="1" SpinButtonPlacementMode="Compact"/>
                <NumberBox x:Name="RepeatMin" Header="Repeat every (min)" Width="150" Minimum="1" SpinButtonPlacementMode="Compact"/>
                <NumberBox x:Name="IdleMin" Header="Idle after (min)" Width="130" Minimum="1" SpinButtonPlacementMode="Compact"/>
            </StackPanel>

            <TextBlock Text="ACTIVITY KEYWORDS  ·  one per line, matched inside window titles" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="RulesOn" Grid.Column="0" Header="On-plan" AcceptsReturn="True" Height="160" TextWrapping="NoWrap"/>
                <TextBox x:Name="RulesOff" Grid.Column="1" Header="Off-plan" AcceptsReturn="True" Height="160" TextWrapping="NoWrap"/>
                <TextBox x:Name="RulesNeutral" Grid.Column="2" Header="Neutral" AcceptsReturn="True" Height="160" TextWrapping="NoWrap"/>
            </Grid>

            <TextBlock Text="IDLE-ANSWER LIBRARY  ·  classifies what you type after being away" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="IdleOn" Grid.Column="0" Header="Counts as on-plan" AcceptsReturn="True" Height="120" TextWrapping="NoWrap"/>
                <TextBox x:Name="IdleOff" Grid.Column="1" Header="Counts as off-plan" AcceptsReturn="True" Height="120" TextWrapping="NoWrap"/>
                <TextBox x:Name="IdleNeutral" Grid.Column="2" Header="Counts as neutral" AcceptsReturn="True" Height="120" TextWrapping="NoWrap"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="SaveRulesBtn" Content="Save settings" Style="{StaticResource AccentButtonStyle}" Click="SaveRules_Click"/>
                <TextBlock x:Name="SaveStatus" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <TextBlock Text="DATA" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="2,10,0,-6"/>
            <TextBlock x:Name="DataInfo" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
