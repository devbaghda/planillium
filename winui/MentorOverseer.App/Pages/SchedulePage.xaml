<Page
    x:Class="MentorOverseer.App.Pages.SchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer x:Name="Scroller" Padding="32,24,32,24">
        <StackPanel MaxWidth="860" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Schedule" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Name="Subtitle"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,12"/>
            <InfoBar x:Name="SaveErrorBar"
                     Severity="Error"
                     IsOpen="False"
                     Title="Couldn't save that change"
                     Message="The database was briefly busy — try again in a moment."
                     Margin="0,0,0,8"/>
            <StackPanel x:Name="Sections" Spacing="12"/>
        </StackPanel>
    </ScrollViewer>
</Page>
