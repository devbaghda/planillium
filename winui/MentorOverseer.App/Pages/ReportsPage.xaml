<Page
    x:Class="MentorOverseer.App.Pages.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="28,8,28,28">
        <StackPanel MaxWidth="880" HorizontalAlignment="Center" Spacing="0">
            <Grid Margin="0,8,0,10">
                <TextBlock Text="Reports" Style="{StaticResource TitleTextBlockStyle}"/>
                <DropDownButton Content="Export" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuFlyoutItem Text="HTML report (week)" Click="ExportHtml_Click"/>
                            <MenuFlyoutItem x:Name="ExportCsvItem" Text="CSV (this period)" Click="ExportCsv_Click"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </Grid>
            <StackPanel x:Name="PeriodBar" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4"/>
            <StackPanel x:Name="Body" Spacing="0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
