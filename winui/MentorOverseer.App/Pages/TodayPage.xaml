<Page
    x:Class="MentorOverseer.App.Pages.TodayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="28,8,28,28">
        <StackPanel MaxWidth="880" HorizontalAlignment="Stretch" Spacing="0">
            <TextBlock Text="Today" Style="{StaticResource TitleTextBlockStyle}" Margin="0,8,0,2"/>
            <TextBlock x:Name="Subtitle"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,16"/>

            <InfoBar x:Name="OverdueBar"
                     Severity="Warning"
                     IsOpen="False"
                     IsClosable="False"
                     Margin="0,0,0,8">
                <InfoBar.ActionButton>
                    <Button x:Name="ReplanButton" Content="Replan all overdue…" IsEnabled="False"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <StackPanel x:Name="Sections" Spacing="0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
