<Window
    x:Class="MentorOverseer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar: app icon block + name, draggable -->
        <Grid x:Name="TitleBar" Grid.Row="0" Height="40" Padding="16,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Border Width="16" Height="16" CornerRadius="4"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <FontIcon Glyph="&#xE73E;" FontSize="10"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                </Border>
                <TextBlock Text="Mentor Overseer"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <NavigationView x:Name="Nav" Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        PaneDisplayMode="Left"
                        OpenPaneLength="248"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="Nav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Today" Tag="today" IsSelected="True">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE823;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Schedule" Tag="schedule">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE787;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Reports" Tag="reports">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE9D2;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Plans" Tag="plans">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8B7;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel Margin="16,0,16,12" Spacing="8">
                    <Border x:Name="ScoreChip" CornerRadius="8" Padding="14,10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="ScoreValue" Text="—"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       FontSize="18"/>
                            <TextBlock Text="pts" VerticalAlignment="Bottom" Margin="0,0,0,2"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
